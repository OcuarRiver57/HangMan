@{
    ViewData["Title"] = "Dictionary";
}
@model FilteredWordsModel

<h2>Word List</h2>
<a asp-area="" asp-controller="GameInformation" asp-action="AddWord">Add Word</a>

<form asp-controller="GameInformation" asp-action="FilterDictionary" method="post">
    @Html.AntiForgeryToken()
    <input type="text" asp-for="Search" value="@Model.Search" />
    <button type="submit">Search</button>
</form>

<table class="table table-striped" id="dictTable">
    <thead>
        <tr>
            <th>Word</th>
            <th>Length</th>
            <th>Vowels</th>
            <th>Category</th>
            <th>Link</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var w in Model.Words)
        {
            <tr>
                <td>@w.Spelling</td>
                <td>@w.Length</td>
                <td>@w.VowelCount</td>
                <td>@w.Category.Name</td>
                <td>
                    <a href="@{@w.Link}" target="_blank" rel="noopener noreferrer">Definition</a>
                </td>
                <td>
                    <form asp-action="DeleteWord" asp-route-id="@w.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this word?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
<script>
    // Attach click handlers to each header
    document.querySelectorAll("#dictTable th").forEach((header, index) => {
        header.addEventListener("click", () => {
            sortTableByColumn(document.getElementById("dictTable"), index);
        });
    });

    // Sorting function (must be OUTSIDE the loop)
    function sortTableByColumn(table, columnIndex) {
        const tbody = table.tBodies[0];
        const rows = Array.from(tbody.querySelectorAll("tr"));
        const currentDir = table.getAttribute("data-sort-dir");
        const isAscending = currentDir !== "asc"; // toggle

        rows.sort((a, b) => {
            const cellA = a.children[columnIndex].innerText.trim();
            const cellB = b.children[columnIndex].innerText.trim();

            const numA = parseFloat(cellA);
            const numB = parseFloat(cellB);

            // Numeric sort if both values are numbers
            if (!isNaN(numA) && !isNaN(numB)) {
                return isAscending ? numA - numB : numB - numA;
            }

            // Text sort
            return isAscending
                ? cellA.localeCompare(cellB)
                : cellB.localeCompare(cellA);
        });

        // Reinsert sorted rows
        rows.forEach(row => tbody.appendChild(row));

        // Save new direction
        table.setAttribute("data-sort-dir", isAscending ? "asc" : "desc");
    }
</script>
<style>
    #dictTable th {
        cursor: pointer;
    }

    #dictTable td {
        cursor: default;
    }

</style>