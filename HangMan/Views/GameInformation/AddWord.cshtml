@{
    ViewData["Title"] = "Add Word";
    //TODO: not properly submitting catagory from drop down
}
@model AddWordModel

Model
<div class="text-center">
    <h1 class="display-4">@ViewData["title"]</h1>
    <form method="post">
        <label asp-for="Word.Spelling">Word:</label>
        <input type="text" asp-for="Word.Spelling" placeholder="Please enter a real word" id="AddWordSpellingInput">
        <span asp-validation-for="Word.Spelling"></span>
        <br />

        <label asp-for="SelectedCategoryName">Category:</label>
        <select id="CategoryDropDown" asp-for="SelectedCategoryName" required>
            <option value="NewCategory1234567898765432345678765432134567876543">Add New Category</option>
            @foreach (CategoryModel c in Model.Categories)
            {
                <option value=@c.Name>@c.Name</option>
            }
        </select>
        <br />
        <div id="AddNewCatagory" class="pt-4">
            <label> Add New Catagory</label><br />
            <label asp-for="Word.Category.Name">Category Name:</label>
            <input type="text" id="CategoryName" asp-for="Word.Category.Name">
            <span asp-validation-for="Word.Category.Name"></span>
            <br />

            <label asp-for="Word.Category.Description">Category Description:</label>
            <input type="text" id="CategoryDescription" asp-for="Word.Category.Description">
            <span asp-validation-for="Word.Category.Description"></span>
            <br />
        </div>

        <div style="display:none;" id="DrugClassificationInput">
            <label asp-for="Word.DrugClassification">Drug Classification:</label>
            <input type="text" asp-for="Word.DrugClassification" placeholder="Please enter drug classification">
            <span asp-validation-for="Word.DrugClassification"></span>
            <br />

            <label asp-for="Word.DrugIsGeneric">Is Generic:</label>
            <input type="checkbox" asp-for="Word.DrugIsGeneric" />
            <br />
        </div>

        <button type="submit">Add Word</button>
    </form>
</div>
<script>
    const newCategoryValue = "NewCategory1234567898765432345678765432134567876543";

    function updateAddWordVisibility() {
        const dropdown = document.getElementById("CategoryDropDown");
        const categoryName = document.getElementById("CategoryName");
        const addNewCategoryContainer = document.getElementById("AddNewCatagory");
        const drugContainer = document.getElementById("DrugClassificationInput");

        const isNewCategory = dropdown.value === newCategoryValue;
        addNewCategoryContainer.style.display = isNewCategory ? "block" : "none";

        const selectedName = isNewCategory ? (categoryName.value || "") : (dropdown.value || "");
        const isDrug = selectedName.toLowerCase() === "drug" || selectedName.toLowerCase() === "drugs";
        drugContainer.style.display = isDrug ? "block" : "none";
    }

    document.getElementById("CategoryDropDown").addEventListener("change", updateAddWordVisibility);
    document.getElementById("CategoryName").addEventListener("input", updateAddWordVisibility);
    updateAddWordVisibility();
</script>
