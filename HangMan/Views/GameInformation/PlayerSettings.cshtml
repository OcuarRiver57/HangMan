@{
    ViewData["Title"] = "Settings";
}
@model PlayerPreferenceViewModel
<body>
    <h1 class="display-4">@ViewData["title"]</h1>
    <form method="post">
        <label asp-for="Preferences.CustomWord">Custom Word:</label>
        <input type="text" id="CustomWord" asp-for="Preferences.CustomWord">
        <span asp-validation-for="Preferences.CustomWord"></span>
        <br />

        <label asp-for="Preferences.MaxWordLength">Max Random Word Length:</label>
        <input type="number" id="Preferences.MaxWordLength" asp-for="Preferences.MaxWordLength">
        <span asp-validation-for="Preferences.MaxWordLength"></span>
        <br />

        <label asp-for="Preferences.MinWordLength">Minimum Random Word Length:</label>
        <input type="number" id="MinWordLength" asp-for="Preferences.MinWordLength">
        <span asp-validation-for="Preferences.MinWordLength"></span>
        <br />

        <label asp-for="Preferences.Health">Health</label>
        <input type="number" id="Health" asp-for="Preferences.Health">
        <span asp-validation-for="Preferences.Health"></span>
        <br />

        <label asp-for="Preferences.Category">Category:</label>
        <select id="CategoryDropDown" asp-for="Preferences.Category" required>
            @foreach (CategoryModel c in Model.Categories)
            {
                <option value=@c.Name>@c.Name</option>
            }
        </select>
        <br />

        <div id="DrugGenericFilter" style="display:none;">
            <label asp-for="Preferences.DrugIsGeneric">Play Generic Drug Words:</label>
            <input type="checkbox" asp-for="Preferences.DrugIsGeneric" />
            <br />
        </div>

        <button type="submit" name="action" value="save" class="btn btn-success">Save</button>
        <button type="submit" name="action" value="start" class="btn btn-primary">Start Game</button>

    </form>
</body>

<script>
    function updateDrugGenericFilterVisibility() {
        const category = (document.getElementById("CategoryDropDown").value || "").toLowerCase();
        const show = category === "drug" || category === "drugs";
        document.getElementById("DrugGenericFilter").style.display = show ? "block" : "none";
    }

    document.getElementById("CategoryDropDown").addEventListener("change", updateDrugGenericFilterVisibility);
    updateDrugGenericFilterVisibility();
</script>